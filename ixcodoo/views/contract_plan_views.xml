<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ixcodoo_contract_plan_form" model="ir.ui.view">
        <field name="name">ixcodoo.contract.plan.form</field>
        <field name="model">ixcodoo.contract.plan</field>
        <field name="arch" type="xml">
            <form string="Contrato de Plan">
                <header>
                    <button name="action_request_signature"
                            string="Enviar a Firma"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_sync_to_ixc"
                            string="Sincronizar con IXC"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'signed'"/>
                    <button name="action_cancel"
                            string="Cancelar"
                            type="object"
                            invisible="state not in ('draft', 'pending', 'signed')"/>
                    <button name="action_reset_to_draft"
                            string="Volver a Borrador"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,signed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Datos del Contrato">
                            <field name="partner_id"/>
                            <field name="plan_id"/>
                            <field name="starting_date"/>
                            <field name="ending_date"/>
                        </group>
                        <group string="Datos del Cliente">
                            <field name="customer_name"/>
                            <field name="customer_email"/>
                            <field name="customer_phone"/>
                        </group>
                    </group>
                    <group string="Firma Digital">
                        <group>
                            <field name="sign_request_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Sincronizacion IXC"
                           invisible="ixc_sync_state == 'not_synced'">
                        <group>
                            <field name="ixc_contract_id"/>
                            <field name="ixc_sync_state"/>
                            <field name="ixc_last_sync"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="ixcodoo_contract_plan_list" model="ir.ui.view">
        <field name="name">ixcodoo.contract.plan.list</field>
        <field name="model">ixcodoo.contract.plan</field>
        <field name="arch" type="xml">
            <list string="Contratos"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'pending'"
                  decoration-success="state == 'signed'"
                  decoration-danger="state == 'cancelled'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="plan_id"/>
                <field name="starting_date"/>
                <field name="ending_date"/>
                <field name="state"/>
                <field name="ixc_sync_state"/>
            </list>
        </field>
    </record>

    <record id="action_ixcodoo_contract_plan" model="ir.actions.act_window">
        <field name="name">Contratos</field>
        <field name="res_model">ixcodoo.contract.plan</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
