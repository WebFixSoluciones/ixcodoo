<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ixcodoo_data_plan_form" model="ir.ui.view">
        <field name="name">ixcodoo.data.plan.form</field>
        <field name="model">ixcodoo.data.plan</field>
        <field name="arch" type="xml">
            <form string="Plan de Datos">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="price"/>
                        </group>
                        <group>
                            <field name="duration_months"/>
                            <field name="ixc_plan_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ixcodoo_data_plan_list" model="ir.ui.view">
        <field name="name">ixcodoo.data.plan.list</field>
        <field name="model">ixcodoo.data.plan</field>
        <field name="arch" type="xml">
            <list string="Planes de Datos">
                <field name="name"/>
                <field name="price"/>
                <field name="duration_months"/>
                <field name="ixc_plan_id"/>
            </list>
        </field>
    </record>

    <record id="action_ixcodoo_data_plan" model="ir.actions.act_window">
        <field name="name">Planes</field>
        <field name="res_model">ixcodoo.data.plan</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
